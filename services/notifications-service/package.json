{
  "name": "notifications-service",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev:force": "ts-node scripts/force_dev_server.script.ts",
    "dev": "ts-node scripts/dev.script.ts",
    "env:init": "ts-node scripts/init_env.script.ts",
    "env:init:force": "ts-node scripts/init_env.script.ts --force",
    "pm2:init": "ts-node scripts/generate_pm2_config.script.ts",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "resolve:alias": "tsc-alias",
    "compile:ts": "tsc",
    "build": "npm run clean && npm run compile:ts && npm run resolve:alias",
    "deploy": "npm run build && npm run pm2:restart",
    "start": "node dist/index.js",
    "clean": "del-cli dist/*",
    "docker:build": "docker build -t node-prod:latest .",
    "docker:run": "docker run --rm -p 4614:4614 --env-file .env node-prod:latest",
    "docker:ps": "docker ps",
    "docker:logs": "docker compose logs -f api",
    "docker:sh": "docker exec -it api sh",
    "compose:up": "docker compose up -d --build",
    "compose:down": "docker compose down",
    "compose:restart": "docker compose restart api",
    "compose:rebuild": "docker compose up -d --build --force-recreate",
    "compose:logs": "docker compose logs -f",
    "compose:ps": "docker compose ps",
    "dev:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build",
    "dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "dev:logs": "docker compose -f docker-compose.yml -f docker-compose.dev.yml logs -f api",
    "dev:sh": "docker exec -it api sh",
    "dev:restart": "docker compose -f docker-compose.yml -f docker-compose.dev.yml restart api",
    "dev:reset": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down -v && docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build",
    "mongo:sh": "docker exec -it mongo mongosh",
    "mongo:logs": "docker compose logs -f mongo",
    "mongo:reset": "docker compose down -v && docker compose up -d --build",
    "docker:prune": "docker system prune -f",
    "docker:prune:all": "docker system prune -a --volumes -f"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/continuation-local-storage": "^3.2.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.11",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "del-cli": "^6.0.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "@tm/logger": "*",
    "aws-sdk": "^2.1692.0",
    "bcrypt": "^5.1.1",
    "continuation-local-storage": "^3.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "socket.io": "^4.8.3",
    "winston": "^3.13.1"
  }
}
